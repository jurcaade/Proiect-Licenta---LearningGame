  m_text: "<b>INSTRUC\u021AIUNI DE BAZ\u0102:</b>\r\n\r\n<color=#00FFFF>W, A, S,
    D</color> - Deplasare  \r\n<color=#00FFFF>Mouse</color> - Rotirea camerei  \r\n<color=#00FFFF>Space</color>
    - S\u0103ritur\u0103  \r\n\r\n<color=#00FFFF>Click St\xE2nga</color> - Interac\u021Biune
    cu obiectele  \r\n\r\n<size=85%>\r\nApas\u0103 butonul verde pentru a debloca
    u\u0219a \u0219i a avansa la urm\u0103torul nivel.  \r\nPrinde \u0219i mut\u0103
    obiectele pentru a rezolva puzzle-urile.\r\n</size>"
