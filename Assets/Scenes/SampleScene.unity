      m_Calls: []
  m_text: "<align=center><b><size=120%><color=#00FFFF>BINE AI VENIT!</color></size></b></align>\r\n\r\nAcest
    mediu virtual a fost creat pentru a-\u021Bi testa \u0219i consolida cuno\u0219tin\u021Bele
    de programare \xEEntr-un mod interactiv.\r\n\r\n\xCEn fa\u021Ba ta se afl\u0103
    <b>5 camere de testare</b>. Fiecare ascunde un puzzle bazat pe un concept fundamental
    din informatic\u0103, de la logic\u0103 de baz\u0103 p\xE2n\u0103 la algoritmi
    \u0219i structuri de date.\r\n\r\n<size=80%><color=#FF8A00>Analizeaz\u0103 cu
    aten\u021Bie mediul din fiecare\r\ncamer\u0103 pentru a g\u0103si solu\u021Bia.\n
    Mult succes!</color></size>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 537e5f480fff6f343b732feb10d8e358, type: 2}
