      m_Calls: []
  m_text: "<b>OBIECTIV:</b>\r\n\u2022 Cite\u0219te codul de pe ecranul <color=#FF8A00>containerului
    portocaliu</color> pentru a afla num\u0103rul de repet\u0103ri.\r\n\u2022 Arunc\u0103
    acel num\u0103r <b>exact</b> de cuburi \xEEn zona de colectare.\r\n\u2022 Apas\u0103
    <color=#00FF00>[EXECUT\u0102]</color> c\xE2nd indexul <color=#569CD6><b>i</b></color>
    ajunge la valoarea corect\u0103.\r\n\r\n<align=center><size=85%><color=#FF4C4C>Aten\u021Bie:
    Nu dep\u0103\u0219i limita buclei!</color></size></align>"
