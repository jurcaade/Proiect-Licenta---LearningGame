  m_Script: {fileID: 11500000, guid: 3a9d1b8995cea4748a00f57148ef0d77, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  infoText: "<size=125%><b><color=#7BE8FF>LEVEL 2: OPERATORI LOGICI</color></b></size>\r\n\r\n\xCEn
    logic\u0103, fiecare valoare poate fi:\r\n<b>1 = adev\u0103rat</b>\r\n<b>0 =
    fals</b>\r\n\r\n<b>AND</b> este adev\u0103rat doar dac\u0103 ambele valori sunt
    adev\u0103rate.\r\nExemplu: <b>1 AND 1 = 1</b>\r\n\r\n<b>OR</b> este adev\u0103rat
    dac\u0103 cel pu\u021Bin una este adev\u0103rat\u0103.\r\nExemplu: <b>1 OR 0
    = 1</b>\r\n\r\n<b>NOT</b> inverseaz\u0103 valoarea.\r\nExemplu: <b>NOT 1 = 0</b>\r\n\r\n<size=65%><color=#A0A0A0>Apas\u0103
    click pentru a \xEEnchide.</color></size>\r\n"
  interactDistance: 4
  interactKey: 101
  openClip: {fileID: 8300000, guid: ee3b3257f4891fb4dad479cf164dc911, type: 3}
  openVolume: 1
